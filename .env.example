# Public HTTPS origin, without /mcp or a trailing slash.
PUBLIC_BASE_URL=https://avito-mcp.example.com

# User enters this once on the OAuth linking screen. Use a random value.
ACCESS_CODE=replace-with-at-least-16-random-characters

# Signs self-contained bearer tokens. Rotating it revokes every issued token.
TOKEN_SECRET=replace-with-at-least-32-random-bytes
TOKEN_TTL_DAYS=365

DATABASE_PATH=/data/history.sqlite3
PORT=8000

# Category and saved filters are taken from this URL. q, pmax and newest-first
# sorting are supplied by search_avito at call time.
AVITO_DEFAULT_SEARCH_URL="https://www.avito.ru/all/knigi_i_zhurnaly"

# Optional. Prefer an egress you control; third-party proxies add a privacy and
# terms-of-service boundary. Only Avito requests use this proxy.
# AVITO_PROXY_URL=http://user:password@proxy.example:3128

REQUEST_TIMEOUT_SECONDS=20
MAX_RESPONSE_BYTES=6000000
MAX_ITEMS=100
